{
  "name": "llm-proxy-view",
  "version": "2.3.1",
  "description": "LLM Proxy CLI - 代理转发和日志管理工具",
  "bin": {
    "claude-proxy": "bin/cli.js",
    "claude-proxy-channel": "bin/channel.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/config/types.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "ui-dist",
    "app/macos-status-bar/bin/StatusBarApp"
  ],
  "scripts": {
    "build": "rm -rf dist ui-dist && tsc && chmod +x bin/cli.js bin/channel.js && vite build && npm run build:statusbar",
    "build:statusbar": "if [ \"$(uname)\" = Darwin ] && command -v swift >/dev/null 2>&1; then cd app/macos-status-bar && (swift build -c release && mkdir -p bin && cp -f .build/release/StatusBarApp bin/StatusBarApp || echo 'Skipping macOS status bar build (swift build failed)'); else echo 'Skipping macOS status bar build (requires macOS with Swift)'; fi",
    "dev": "tsx src/cli/index.ts",
    "dev:ui": "vite",
    "test": "jest --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ucasYToo/llm-proxy.git"
  },
  "keywords": [
    "claude",
    "llm",
    "proxy",
    "cli",
    "openai",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@larksuiteoapi/node-sdk": "^1.67.0",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "ora": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.4",
    "@types/node": "^22",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jest": "^29.6.4",
    "prettier": "^3.0.2",
    "timeout": "^0.2.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
